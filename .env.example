# =============================================================================
# Lattice local test configuration
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed as documentation.
#
# Strict mode: every variable below must be set explicitly when the
# corresponding code path runs. There are no built-in defaults — a missing
# value is a hard error at startup (real-agent, e2e tests) or at first
# request (lattice-server when the request also omits the field).
# =============================================================================

# -----------------------------------------------------------------------------
# Required for all real-LLM code paths
# -----------------------------------------------------------------------------

# Which provider to use: anthropic | openai
LATTICE_LLM_PROVIDER=openai

# API key. For OpenAI use sk-xxx; for Anthropic use sk-ant-xxx;
# for third-party proxies (DeepSeek, MiniMax, …) use their key format.
LATTICE_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic provider (required when LATTICE_LLM_PROVIDER=anthropic)
# Consumers: tests/e2e.rs::test_end_to_end_anthropic, real-agent, lattice-server
# -----------------------------------------------------------------------------

# Base URL for Anthropic Messages API.
# Official:                  https://api.anthropic.com
# DeepSeek Anthropic-compat: https://api.deepseek.com/anthropic
LATTICE_ANTHROPIC_API_BASE=https://api.anthropic.com

# Model name for the Anthropic provider.
# Examples: claude-sonnet-4-20250514, deepseek-v4-flash
LATTICE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# OpenAI provider (required when LATTICE_LLM_PROVIDER=openai)
# Consumers: tests/e2e.rs::test_end_to_end_openai, llm-openai integration tests,
#            real-agent, lattice-server
# -----------------------------------------------------------------------------

# Base URL for OpenAI Chat Completions API.
# Official:        https://api.openai.com/v1
# DeepSeek:        https://api.deepseek.com
# MiniMax:         https://api.minimax.chat
# Local (Ollama):  http://localhost:11434
LATTICE_OPENAI_API_BASE=https://api.openai.com/v1

# Model name for the OpenAI provider.
# Examples: gpt-4o, deepseek-chat, MiniMax-M2.7
LATTICE_OPENAI_MODEL=gpt-4o
